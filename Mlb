<script>
// ── Keys ─────────────────────────────────────────────────
let antKey  = localStorage.getItem('tb_ant')  || '';
let oddsKey = localStorage.getItem('tb_odds') || '';

// ── Config ────────────────────────────────────────────────
const CONF = {
  'STRONG BET':{ color:'#00ff9d', bg:'rgba(0,255,157,0.09)', border:'rgba(0,255,157,0.32)' },
  'VALUE':     { color:'#f0c040', bg:'rgba(240,192,64,0.08)', border:'rgba(240,192,64,0.32)' },
  'LEAN':      { color:'#5a9ad8', bg:'rgba(90,154,216,0.06)', border:'rgba(90,154,216,0.22)' },
  'PASS':      { color:'#334',    bg:'rgba(20,25,35,0.4)',    border:'rgba(40,55,70,0.28)'  },
};
const ORDER = {'STRONG BET':0,'VALUE':1,'LEAN':2,'PASS':3};
const fmt = (n,d=1) => n!=null&&n!=='' ? Number(n).toFixed(d) : '—';
const pct = (n,d=1) => n!=null&&n!=='' ? (Number(n)*100).toFixed(d)+'%' : '—';
const $ = id => document.getElementById(id);

const LOAD_STEPS = [
  'Fetching live MLB odds…',
  'Pulling today\'s schedule…',
  'Computing Pythagorean %…',
  'Adjusting cluster luck…',
  'Running Log5 formula…',
  'Applying SIERA pitcher adj…',
  'Calculating Kelly sizes…',
  'Building analysis…'
];

const SYSTEM_PROMPT = `You are a baseball analytics engine implementing Joe Peta's COMPLETE Trading Bases methodology.

You will receive real MLB game data from the Odds API including teams, game times, and Vegas moneylines.

Using your knowledge of the 2026 MLB season (team RS/RA totals, pitcher SIERA/WAR, standings), apply the full formula:

STEP 1 — PYTHAGOREAN WIN% (exponent 1.83):
  PythagWin% = RS^1.83 / (RS^1.83 + RA^1.83)

STEP 2 — CLUSTER LUCK:
  clusterLuckWins = actualWins - pythagoreanExpectedWins
  clusterAdjWin% = PythagWin% + (clusterLuckWins * 0.30 / gamesPlayed)

STEP 3 — LOG5:
  P(A beats B) = (A - A*B) / (A + B - 2*A*B)

STEP 4 — SIERA PITCHER ADJUSTMENT:
  skillsWAR = WAR * min(starts/10, 1.0)
  Add (skillsWAR * 5) wins to team total, re-run Log5.

STEP 5 — HOME FIELD: multiply home prob by 1.08, normalize.

STEP 6 — PARK FACTOR: Coors=1.14, Petco/Oracle=0.92, etc.

STEP 7 — EDGE vs REAL VEGAS LINE:
  Use the actual moneyline provided to compute vegasImpliedHome.
  edge = finalHomeWinPct - vegasImpliedHome  (if picking home)
  or   = finalAwayWinPct - vegasImpliedAway  (if picking away)
  Take the side with positive edge.
  STRONG BET >5%, VALUE >2%, LEAN >0%, PASS <=0%

STEP 8 — KELLY: kellyFull=edge/(1-modelProb), kellyHalf=kellyFull/2, cap recommendedBetPct at 5%.

Return ONLY a raw JSON array, no markdown. Each element needs ALL fields:
gameId, homeTeam, awayTeam, homeStarter, awayStarter, gameTime,
homeRecord, awayRecord, homeRS, homeRA, awayRS, awayRA,
homePythag, awayPythag,
homeClusterLuckWins, awayClusterLuckWins, homeClusterAdj, awayClusterAdj,
log5Base, homeStarterWAR, homeStarterRegressedWAR, homeSIERA,
awayStarterWAR, awayStarterRegressedWAR, awaySIERA, log5AfterPitcher,
parkFactor, parkName, parkAdjNote,
finalHomeWinPct, finalAwayWinPct,
vegasImpliedHome, vegasImpliedAway, homeMoneyline, awayMoneyline, edge,
kellyFull, kellyHalf, recommendedBetPct,
recommendedPick, pickTeamName, confidence, reasoning`;

// ── Modal ─────────────────────────────────────────────────
function openModal() {
  $('ant-inp').value  = antKey;
  $('odds-inp').value = oddsKey;
  $('modal').classList.add('on');
  $('modal').style.display = 'flex';
  setTimeout(()=>{ if(!antKey) $('ant-inp').focus(); else $('odds-inp').focus(); }, 150);
}
function closeModal() {
  $('modal').classList.remove('on');
  $('modal').style.display = 'none';
}
$('modal').addEventListener('click', e => { if(e.target===$('modal')) closeModal(); });
$('key-btn').addEventListener('click', openModal);
$('key-save').addEventListener('click', () => {
  const a = $('ant-inp').value.trim();
  const o = $('odds-inp').value.trim();
  if(!a){ alert('Anthropic API key is required'); return; }
  antKey = a; oddsKey = o;
  localStorage.setItem('tb_ant', a);
  if(o) localStorage.setItem('tb_odds', o);
  closeModal();
  updateSubtitle();
  $('empty').textContent = "Keys saved! Tap Run Analysis to load today's games.";
  on('empty');
});

function updateSubtitle() {
  $('hdr-sub').innerHTML = oddsKey
    ? '<span class="live-dot"></span>Live Odds · Pythagorean · Cluster Luck · Log5 · SIERA · Kelly'
    : 'Pythagorean · Cluster Luck · Log5 · SIERA · Kelly';
}

// ── State helpers ─────────────────────────────────────────
let allGames = [], currentFilter = 'ALL', loadTimer = null, loadIdx = 0;
const on  = id => { const e=$(id); if(e){e.classList.add('on');e.style.display='';} };
const off = id => { const e=$(id); if(e){e.classList.remove('on');e.style.display='none';} };
function showErr(msg){ $('err-box').innerHTML='<strong>⚠️ Error</strong><br>'+msg; on('err-box'); }

// ── Filter tabs ───────────────────────────────────────────
document.querySelectorAll('.ftab').forEach(b => {
  b.addEventListener('click', () => {
    currentFilter = b.dataset.f;
    document.querySelectorAll('.ftab').forEach(x=>x.classList.remove('on'));
    b.classList.add('on');
    renderGames();
  });
});

// ── Odds API fetch ────────────────────────────────────────
async function fetchOddsData() {
  if(!oddsKey) return null;
  try {
    const url = `https://api.the-odds-api.com/v4/sports/baseball_mlb/odds/?apiKey=${oddsKey}&regions=us&markets=h2h&oddsFormat=american&dateFormat=iso`;
    const res = await fetch(url);
    if(!res.ok) {
      const t = await res.text();
      console.warn('Odds API error:', res.status, t.slice(0,200));
      return null;
    }
    const data = await res.json();
    return data;
  } catch(e) {
    console.warn('Odds API fetch failed:', e.message);
    return null;
  }
}

function parseOddsData(oddsData) {
  if(!oddsData || !Array.isArray(oddsData)) return [];
  return oddsData.map(game => {
    const home = game.home_team;
    const away = game.away_team;
    let homeML = null, awayML = null;
    try {
      const bk = game.bookmakers?.[0];
      const mkt = bk?.markets?.find(m=>m.key==='h2h');
      if(mkt) {
        homeML = mkt.outcomes?.find(o=>o.name===home)?.price ?? null;
        awayML = mkt.outcomes?.find(o=>o.name===away)?.price ?? null;
      }
    } catch{}
    const dt = new Date(game.commence_time);
    const timeStr = dt.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',timeZoneName:'short'});
    return { gameId:game.id, homeTeam:home, awayTeam:away, gameTime:timeStr, homeMoneyline:homeML, awayMoneyline:awayML };
  });
}

function mlToImplied(ml) {
  if(ml == null) return null;
  return ml > 0 ? 100/(ml+100) : Math.abs(ml)/(Math.abs(ml)+100);
}

// ── Main fetch ────────────────────────────────────────────
$('run-btn').addEventListener('click', runAnalysis);

async function runAnalysis() {
  if(!antKey){ openModal(); return; }
  $('run-btn').disabled = true;
  $('run-btn').textContent = 'ANALYZING…';
  on('loading'); off('err-box'); off('empty');
  $('stats-grid').style.display = 'none';
  $('best-bet').style.display = 'none';
  $('disc').style.display = 'none';
  $('filters').style.display = 'none';
  $('games-list').innerHTML = '';
  $('last-run').textContent = '';
  allGames = [];

  loadIdx = 0;
  $('load-s').textContent = LOAD_STEPS[0];
  clearInterval(loadTimer);
  loadTimer = setInterval(()=>{ loadIdx=(loadIdx+1)%LOAD_STEPS.length; $('load-s').textContent=LOAD_STEPS[loadIdx]; }, 900);

  try {
    // Step 1: Fetch real odds if key provided
    let oddsGames = [];
    let oddsContext = '';
    if(oddsKey) {
      const raw = await fetchOddsData();
      oddsGames = parseOddsData(raw);
      if(oddsGames.length) {
        oddsContext = `\n\nREAL ODDS API DATA (use these exact teams, times, and moneylines):\n${JSON.stringify(oddsGames, null, 2)}\n\nFor each game above, look up the 2026 season stats and run the full Trading Bases formula. Use the real moneylines for edge calculation.`;
      }
    }

    const today = new Date().toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
    const userMsg = oddsContext
      ? `Today is ${today}. Analyze these real MLB games using Trading Bases methodology:${oddsContext}\n\nReturn ONLY the raw JSON array.`
      : `Today is ${today}. Generate today's full MLB schedule with Trading Bases analysis (10-15 games). Use your 2026 MLB knowledge. Return ONLY the raw JSON array.`;

    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': antKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 6000,
        system: SYSTEM_PROMPT,
        messages: [{ role:'user', content: userMsg }]
      })
    });

    const bodyText = await res.text();
    let data;
    try { data = JSON.parse(bodyText); }
    catch { throw new Error('HTTP '+res.status+': '+bodyText.slice(0,250)); }
    if(!res.ok||data.error) throw new Error('API '+(data.error?.message||res.status+': '+bodyText.slice(0,200)));
    if(!data.content?.length) throw new Error('Empty API response');

    const text = data.content.filter(b=>b.type==='text').map(b=>b.text).join('');
    const m = text.match(/\[[\s\S]*\]/);
    if(!m) throw new Error('No JSON array in response: '+text.slice(0,300));

    let parsed;
    try { parsed = JSON.parse(m[0]); }
    catch(e) { throw new Error('JSON parse: '+e.message); }
    if(!Array.isArray(parsed)||!parsed.length) throw new Error('Empty games array');

    // Merge real moneylines back in if we have them
    if(oddsGames.length) {
      parsed.forEach(g => {
        const match = oddsGames.find(o =>
          o.homeTeam.toLowerCase().includes(g.homeTeam?.toLowerCase()?.split(' ').pop()||'') ||
          g.homeTeam?.toLowerCase().includes(o.homeTeam?.toLowerCase()?.split(' ').pop()||'')
        );
        if(match) {
          if(match.homeMoneyline != null) g.homeMoneyline = match.homeMoneyline;
          if(match.awayMoneyline != null) g.awayMoneyline = match.awayMoneyline;
          if(!g.vegasImpliedHome && match.homeMoneyline) g.vegasImpliedHome = mlToImplied(match.homeMoneyline);
          if(!g.vegasImpliedAway && match.awayMoneyline) g.vegasImpliedAway = mlToImplied(match.awayMoneyline);
        }
      });
    }

    parsed.sort((a,b)=>(ORDER[a.confidence]??3)-(ORDER[b.confidence]??3));
    allGames = parsed;
    $('last-run').textContent = new Date().toLocaleTimeString();
    updateCounts();
    renderGames();

  } catch(e) {
    showErr(e.message||String(e));
  } finally {
    clearInterval(loadTimer);
    off('loading');
    $('run-btn').disabled = false;
    $('run-btn').textContent = 'RUN ANALYSIS';
  }
}

function updateCounts() {
  const c={ALL:allGames.length,'STRONG BET':0,VALUE:0,LEAN:0,PASS:0};
  allGames.forEach(g=>{if(c[g.confidence]!==undefined)c[g.confidence]++;});
  document.querySelectorAll('.ftab').forEach(b=>{ b.textContent=b.dataset.f+' ('+(c[b.dataset.f]??0)+')'; });
}

function renderGames() {
  const games = currentFilter==='ALL' ? allGames : allGames.filter(g=>g.confidence===currentFilter);
  $('games-list').innerHTML = '';
  if(!games.length){
    on('empty'); $('empty').textContent='No games match this filter.';
    $('stats-grid').style.display='none'; $('best-bet').style.display='none';
    $('disc').style.display='none'; $('filters').style.display='none';
    return;
  }
  off('empty');
  $('stats-grid').style.display='grid'; $('filters').style.display='flex'; $('disc').style.display='block';
  const strong=allGames.filter(g=>g.confidence==='STRONG BET').length;
  const value=allGames.filter(g=>g.confidence==='STRONG BET'||g.confidence==='VALUE').length;
  const pos=allGames.filter(g=>g.edge>0);
  $('s-games').textContent=allGames.length;
  $('s-strong').textContent=strong;
  $('s-value').textContent=value;
  $('s-edge').textContent=pos.length?fmt(pos.reduce((s,g)=>s+(g.edge||0),0)/pos.length)+'%':'—';
  const top=allGames.find(g=>g.confidence==='STRONG BET');
  if(top){
    $('bb-team').textContent=top.pickTeamName;
    $('bb-detail').textContent=top.awayTeam+' @ '+top.homeTeam+' · '+pct(top.recommendedPick==='HOME'?top.finalHomeWinPct:top.finalAwayWinPct)+' · +'+fmt(top.edge)+'% edge · Bet '+fmt(top.recommendedBetPct)+'%';
    $('best-bet').style.display='flex';
  } else { $('best-bet').style.display='none'; }
  games.forEach((g,i)=>$('games-list').appendChild(buildCard(g,i)));
}

// ── Card builder ──────────────────────────────────────────
function buildCard(g, idx) {
  const cfg=CONF[g.confidence]||CONF['PASS'];
  const ap=((g.finalAwayWinPct||0)*100).toFixed(1);
  const hp=((g.finalHomeWinPct||0)*100).toFixed(1);
  const pickP=pct(g.recommendedPick==='HOME'?g.finalHomeWinPct:g.finalAwayWinPct);
  const edgeStr=g.confidence!=='PASS'&&g.edge!=null?' +'+fmt(g.edge)+'%':'';
  const isPark=g.parkFactor&&Math.abs(g.parkFactor-1)>0.03;
  const parkLbl=g.parkFactor>1.05?'🏔 HITTER':'🛡 PITCHER';
  const hasRealOdds=g.homeMoneyline!=null;

  const el=document.createElement('div');
  el.className='card';
  el.style.cssText=`border:1px solid ${cfg.border};background:${cfg.bg};animation:rise .4s ease ${idx*.055}s both`;

  let isOpen=false, activeTab='formula';

  el.innerHTML=`
    <div class="card-hdr" id="ch${idx}">
      <div class="card-top">
        <div class="teams-row">
          <span class="t-away">${g.awayTeam}</span>
          <span class="t-at">@</span>
          <span class="t-home">${g.homeTeam}</span>
          ${isPark?`<span class="park-pill">${parkLbl}</span>`:''}
        </div>
        <div class="badge-col">
          <div class="badge" style="color:${cfg.color}">${g.confidence}${edgeStr}</div>
          ${g.gameTime?`<div class="gt">${g.gameTime}</div>`:''}
          ${hasRealOdds?`<div class="ml-line">${g.awayMoneyline>0?'+':''}${g.awayMoneyline} / ${g.homeMoneyline>0?'+':''}${g.homeMoneyline}</div>`:''}
        </div>
      </div>
      <div class="pitchers">
        <span>⚾ ${g.awayStarter||'TBD'} <span class="p-war">SIERA ${fmt(g.awaySIERA)} · WAR ${fmt(g.awayStarterWAR)}</span></span>
        <span style="color:var(--b3)">vs</span>
        <span>⚾ ${g.homeStarter||'TBD'} <span class="p-war">SIERA ${fmt(g.homeSIERA)} · WAR ${fmt(g.homeStarterWAR)}</span></span>
      </div>
      <div class="wb-labels">
        <span style="color:var(--blue)">${g.awayTeam} ${ap}%</span>
        <span style="color:var(--orange)">${hp}% ${g.homeTeam}</span>
      </div>
      <div class="wb-track">
        <div class="wb-away-bar" style="width:${ap}%"></div>
        <div class="wb-home-bar"></div>
      </div>
      <div class="pick-row">
        ${g.recommendedPick!=='PASS'?`
          <div class="pick-left">
            <span class="pick-tag">PICK</span>
            <span class="pick-team" style="color:${cfg.color}">${g.pickTeamName}</span>
            <span class="pick-prob">${pickP}</span>
          </div>
          ${g.recommendedBetPct!=null?`<span class="kelly-pill">BET ${fmt(g.recommendedBetPct)}%</span>`:''}`
        :`<span style="font-size:10px;color:var(--t4)">No edge — pass</span>`}
      </div>
      ${hasRealOdds?`<div class="odds-source"><span class="live-dot"></span>Real Vegas odds via Odds API</div>`:''}
    </div>
    <div class="card-body" id="cb${idx}" style="display:none">
      <div class="tabs">
        <button class="tab-btn on" data-t="formula" style="color:${cfg.color}">Formula</button>
        <button class="tab-btn" data-t="matchup">Matchup</button>
        <button class="tab-btn" data-t="kelly">Kelly</button>
      </div>
      <div class="tc" id="tc${idx}">${fmtFormula(g,cfg)}</div>
    </div>`;

  el.querySelector(`#ch${idx}`).addEventListener('click',()=>{
    isOpen=!isOpen;
    el.querySelector(`#cb${idx}`).style.display=isOpen?'':'none';
  });
  el.querySelectorAll('.tab-btn').forEach(b=>{
    b.addEventListener('click',e=>{
      e.stopPropagation();
      activeTab=b.dataset.t;
      el.querySelectorAll('.tab-btn').forEach(x=>{x.classList.remove('on');x.style.color='var(--t4)';});
      b.classList.add('on'); b.style.color=cfg.color;
      el.querySelector(`#tc${idx}`).innerHTML=
        activeTab==='formula'?fmtFormula(g,cfg):activeTab==='matchup'?fmtMatchup(g):fmtKelly(g,cfg);
    });
  });
  return el;
}

const stepH = (n,l) => `<div class="step"><div class="step-n">${n}</div><span class="step-l">${l}</span></div>`;
const srH = (l,v,s='',hl='') => `<div class="sr"><span class="sr-l">${l}</span><div><span class="sr-v"${hl?` style="color:${hl}"`:''}>  ${v}</span>${s?`<span class="sr-s">${s}</span>`:''}</div></div>`;
const luckCol = v => v>1.5?'#f0c040':v<-1.5?'#a05050':'';

function fmtFormula(g,cfg){ return `
  ${stepH('1','Pythagorean Win%')}
  <div class="g2">
    ${srH(g.awayTeam+' Pythag',pct(g.awayPythag),g.awayRS+'RS/'+g.awayRA+'RA')}
    ${srH(g.homeTeam+' Pythag',pct(g.homePythag),g.homeRS+'RS/'+g.homeRA+'RA')}
  </div>
  ${stepH('2','Cluster Luck')}
  <div class="g2">
    ${srH(g.awayTeam+' luck',(g.awayClusterLuckWins>0?'+':'')+fmt(g.awayClusterLuckWins)+' W','',luckCol(g.awayClusterLuckWins))}
    ${srH(g.homeTeam+' luck',(g.homeClusterLuckWins>0?'+':'')+fmt(g.homeClusterLuckWins)+' W','',luckCol(g.homeClusterLuckWins))}
    ${srH(g.awayTeam+' adj',pct(g.awayClusterAdj))}
    ${srH(g.homeTeam+' adj',pct(g.homeClusterAdj))}
  </div>
  ${stepH('3','Log5 H2H')}
  ${srH('Log5 base (home)',pct(g.log5Base),'(A–A×B)/(A+B–2AB)')}
  ${stepH('4','SIERA Pitcher Adj')}
  <div class="g2">
    ${srH((g.awayStarter||'Away').split(' ').pop()+' SIERA',fmt(g.awaySIERA))}
    ${srH((g.homeStarter||'Home').split(' ').pop()+' SIERA',fmt(g.homeSIERA))}
    ${srH('Away WAR (reg)',fmt(g.awayStarterRegressedWAR))}
    ${srH('Home WAR (reg)',fmt(g.homeStarterRegressedWAR))}
  </div>
  ${srH('Log5 after pitchers',pct(g.log5AfterPitcher),'','#5a9ad8')}
  ${stepH('5+6','HFA + Park')}
  ${srH('Home field boost','+8%')}
  ${g.parkFactor?srH('Park ('+g.parkName+')',fmt(g.parkFactor)+'×',g.parkAdjNote||''):''}
  ${srH('Final home prob',pct(g.finalHomeWinPct),'',cfg.color)}
`;}

function fmtMatchup(g){ return `
  ${stepH('📊','Season Stats')}
  <div class="g2">
    ${srH(g.awayTeam+' record',g.awayRecord||'—')}
    ${srH(g.homeTeam+' record',g.homeRecord||'—')}
  </div>
  ${g.homeMoneyline!=null?`
    ${stepH('💹','Vegas Lines')}
    <div class="g2">
      ${srH(g.awayTeam+' ML',(g.awayMoneyline>0?'+':'')+g.awayMoneyline)}
      ${srH(g.homeTeam+' ML',(g.homeMoneyline>0?'+':'')+g.homeMoneyline)}
      ${srH(g.awayTeam+' implied',pct(g.vegasImpliedAway))}
      ${srH(g.homeTeam+' implied',pct(g.vegasImpliedHome))}
    </div>`:''}
  ${stepH('📝','Analysis')}
  <div class="reasoning">${g.reasoning||'—'}</div>
`;}

function fmtKelly(g,cfg){
  const modelP=g.recommendedPick==='HOME'?g.finalHomeWinPct:g.finalAwayWinPct;
  return `
  ${stepH('💰','Kelly Criterion')}
  ${srH('Model prob',pct(modelP),'','#5a9ad8')}
  ${srH('Vegas implied',pct(g.recommendedPick==='HOME'?g.vegasImpliedHome:g.vegasImpliedAway))}
  ${g.homeMoneyline!=null?srH('Moneyline',(g.recommendedPick==='HOME'?(g.homeMoneyline>0?'+':'')+g.homeMoneyline:(g.awayMoneyline>0?'+':'')+g.awayMoneyline),'real odds'):''}
  ${srH('Edge','+'+fmt(g.edge)+'%','',cfg.color)}
  <div style="height:1px;background:rgba(255,255,255,.04);margin:8px 0"></div>
  ${srH('Full Kelly',fmt((g.kellyFull||0)*100)+'% bankroll')}
  ${srH('Half Kelly',fmt((g.kellyHalf||0)*100)+'% bankroll','','#00cc77')}
  ${srH('Capped bet',fmt(g.recommendedBetPct)+'% bankroll','','#00ff9d')}
  <div class="kelly-note">Half-Kelly minimizes ruin risk. Edge must persist over 50+ games for statistical significance.</div>
`;}

// ── iOS install ───────────────────────────────────────────
if(/iphone|ipad|ipod/i.test(navigator.userAgent)&&!navigator.standalone){
  setTimeout(()=>{ on('install'); setTimeout(()=>off('install'),9000); },3000);
}
$('install').addEventListener('click',()=>off('install'));

// ── Service worker ────────────────────────────────────────
if('serviceWorker' in navigator){
  const sw=`const C='tb-v3';self.addEventListener('install',e=>self.skipWaiting());self.addEventListener('activate',e=>e.waitUntil(self.clients.claim()));self.addEventListener('fetch',e=>{if(e.request.url.includes('anthropic.com')||e.request.url.includes('odds-api.com'))return;e.respondWith(caches.open(C).then(c=>c.match(e.request).then(r=>r||fetch(e.request).then(res=>{c.put(e.request,res.clone());return res;}))));});`;
  navigator.serviceWorker.register(URL.createObjectURL(new Blob([sw],{type:'application/javascript'}))).catch(()=>{});
}

// ── Init ──────────────────────────────────────────────────
updateSubtitle();
if(!antKey){ setTimeout(openModal,600); }
else { $('empty').textContent="Tap Run Analysis to load today's games"; on('empty'); }
</script>

